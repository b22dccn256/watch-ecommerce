{
	"name": "e-commerce-store",
	"version": "1.0.0",
	"description": "<h1 align=\"center\">E-Commerce Store 🛒</h1>",
	"main": "backend/server.js",
	"scripts": {
		"server": "nodemon backend/server.js",
		"client": "npm run dev --prefix frontend",
		"dev:clean": "node scripts/clean-dev.js",
		"dev": "npm run dev:clean && concurrently \"npm run server\" \"npm run client\"",
		"start": "node backend/server.js",
		"install:all": "npm install && npm install --prefix backend && npm install --prefix frontend --include=dev",
		"build": "npm run build --prefix frontend",
		"seed:admin": "node backend/scripts/seed-admin.js",
		"seed:real": "node backend/scripts/seed-real-products.js",
		"migrate": "node backend/scripts/migrate-all.js",
		"migrate:indexes": "node backend/scripts/ensure-indexes.js",
		"test:coupon": "node backend/scripts/run-coupon-tests.mjs",
		"audit": "npm audit && npm audit --prefix frontend",
		"docker:up": "docker-compose up --build -d",
		"docker:down": "docker-compose down",
		"docker:logs": "docker-compose logs -f"
	},
	"keywords": [],
	"author": "",
	"type": "module",
	"license": "ISC",
	"dependencies": {
		"@google/genai": "^1.44.0",
		"@google/generative-ai": "^0.24.1",
		"bcryptjs": "^2.4.3",
		"bullmq": "^5.71.0",
		"cloudinary": "^2.9.0",
		"cookie-parser": "^1.4.7",
		"cors": "^2.8.6",
		"dotenv": "^16.6.1",
		"express": "^4.22.1",
		"express-rate-limit": "^8.3.1",
		"helmet": "^8.1.0",
		"ioredis": "^5.10.0",
		"joi": "^18.2.1",
		"jsonwebtoken": "^9.0.3",
		"mongodb": "^7.1.0",
		"mongoose": "^9.3.0",
		"multer": "^2.1.1",
		"node-cron": "^4.2.1",
		"nodemailer": "^8.0.1",
		"path": "^0.12.7",
		"slugify": "^1.6.6",
		"stripe": "^16.12.0",
		"vnpay": "^2.5.0",
		"xlsx": "^0.18.5"
	},
	"devDependencies": {
		"concurrently": "^9.2.1",
		"nodemon": "^3.1.14"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/burakorkmez/mern-ecommerce.git"
	},
	"bugs": {
		"url": "https://github.com/burakorkmez/mern-ecommerce/issues"
	},
	"homepage": "https://github.com/burakorkmez/mern-ecommerce#readme"
}
